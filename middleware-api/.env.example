APP_NAME="Hungry 4 Joy Middleware API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Match this to the URL printed by `php artisan serve`.
APP_URL=http://127.0.0.1:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Foxy JSON webhook encryption key. Keep this empty until configuring a signed webhook endpoint.
FOXY_WEBHOOK_ENCRYPTION_KEY=
FOXY_CLIENT_ID=
FOXY_CLIENT_SECRET=
FOXY_REFRESH_TOKEN=
FOXY_STORE_ID=

# Checkout handoff registration from the WordPress browser (enabled by default).
CHECKOUT_HANDOFF_REGISTRATION_ENABLED=true
CHECKOUT_HANDOFF_ABANDON_AFTER_HOURS=24

# HubSpot CRM sync is disabled by default. Tests and local development use the fake client unless enabled with a token.
HUBSPOT_ENABLED=false
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_NEWSLETTER_LIST_ID=12

# Comma-separated browser origins allowed to call /api (dashboard Vite dev + hosted WordPress).
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174,https://hungry-4-joy-wordpress.onrender.com

# Local sqlite storage is enough for receiver verification and safe checkout event rows.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=hungry_4_joy_backend
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
